<assembly>
    <id>release</id>
    <formats>
        <format>zip</format>
    </formats>

    <baseDirectory>soloncode-cli</baseDirectory>

    <fileSets>

        <!-- soloncode-cli -->
        <fileSet>
            <directory>${project.build.directory}</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>soloncode-cli.jar</include>
            </includes>
        </fileSet>

        <!-- scripts (install/uninstall/run) -->
        <fileSet>
            <directory>${project.basedir}/../bin</directory>
            <outputDirectory>.</outputDirectory>
            <fileMode>0755</fileMode>
            <includes>
                <include>install.sh</include>
                <include>install.cmd</include>
                <include>uninstall.sh</include>
                <include>uninstall.cmd</include>
                <include>run.sh</include>
                <include>run.cmd</include>
            </includes>
        </fileSet>

        <!-- docs -->
        <fileSet>
            <directory>${project.basedir}/../bin</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>AGENTS.md</include>
                <include>README.md</include>
            </includes>
        </fileSet>

        <!-- default config template (placed in .soloncode/ subdirectory) -->
        <fileSet>
            <directory>${project.basedir}/../bin</directory>
            <outputDirectory>.soloncode</outputDirectory>
            <includes>
                <include>config.yml</include>
            </includes>
        </fileSet>

    </fileSets>
</assembly>

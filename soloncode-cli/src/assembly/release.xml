<assembly>
    <id>release</id>
    <formats>
        <format>tar.gz</format>
    </formats>

    <baseDirectory>soloncode-cli</baseDirectory>

    <fileSets>

        <!-- soloncode-cli -->
        <fileSet>
            <directory>${project.build.directory}</directory>
            <outputDirectory>./bin</outputDirectory>
            <includes>
                <include>soloncode-cli.jar</include>
            </includes>
        </fileSet>

        <!-- scripts (install/uninstall/run) -->
        <fileSet>
            <directory>${project.basedir}/release</directory>
            <outputDirectory>.</outputDirectory>
            <fileMode>0755</fileMode>
            <includes>
                <include>install.sh</include>
                <include>install.ps1</include>
            </includes>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}/release/bin</directory>
            <outputDirectory>./bin</outputDirectory>
            <fileMode>0755</fileMode>
            <includes>
                <include>uninstall.sh</include>
                <include>uninstall.ps1</include>
            </includes>
        </fileSet>

        <!-- skills -->
        <fileSet>
            <directory>${project.basedir}/release/skills</directory>
            <outputDirectory>./skills</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>

        <!-- default config template (placed in .soloncode/ subdirectory) -->
        <fileSet>
            <directory>${project.basedir}/release/bin</directory>
            <outputDirectory>./bin</outputDirectory>
            <includes>
                <include>config.yml</include>
                <include>AGENTS.md</include>
            </includes>
        </fileSet>

    </fileSets>
</assembly>
